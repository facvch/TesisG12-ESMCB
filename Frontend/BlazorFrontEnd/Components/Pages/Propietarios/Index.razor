@page "/propietarios"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject PropietarioService PropietarioService
@inject NavigationManager Navigation

<PageTitle>Clientes / Propietarios</PageTitle>

<div class="d-flex justify-content-between align-items-center" style="margin-bottom: var(--sp-lg);">
    <div>
        <h2 style="font-weight: 700; margin: 0;">Directorio de Clientes</h2>
        <p class="text-secondary" style="margin: 0;">Gestión de propietarios de mascotas</p>
    </div>
    <a href="/propietarios/nuevo" class="btn-primary-glass" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 20px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Nuevo Cliente
    </a>
</div>

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2" style="margin-bottom: var(--sp-md);">
        <h4 style="margin: 0;">Lista de Clientes</h4>
        <div class="d-flex gap-2">
            <input type="text" @bind="searchTerm" @bind:after="OnSearchChanged" class="form-control" placeholder="Buscar por DNI o Apellido..." style="width: 300px;" />
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <button class="btn btn-outline-secondary" @onclick="ClearSearch" title="Limpiar filtro">
                    Limpiar
                </button>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <p class="text-secondary">Cargando datos...</p>
    }
    else if (propietariosResponse?.Items == null || !propietariosResponse.Items.Any())
    {
        <p class="text-secondary">No se encontraron clientes.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover" style="background: transparent;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-glass);">
                        <th>Nombre Completo</th>
                        <th>DNI</th>
                        <th>Teléfono</th>
                        <th>Mascotas</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var prop in propietariosResponse.Items)
                    {
                        <tr style="border-bottom: 1px solid var(--border-glass);">
                            <td>
                                <strong>@prop.NombreCompleto</strong>
                                <br/><small class="text-secondary">@prop.Email</small>
                            </td>
                            <td>@prop.DNI</td>
                            <td>@prop.Telefono</td>
                            <td>
                                <span style="background: var(--accent-secondary); color: white; padding: 2px 8px; border-radius: 12px; font-size: 0.8rem;">
                                    @prop.CantidadMascotas
                                </span>
                            </td>
                            <td>
                                @if(prop.Activo) { <span style="color: var(--accent-primary);">Activo</span> }
                                else { <span style="color: var(--accent-danger);">Inactivo</span> }
                            </td>
                            <td class="text-end">
                                <a href="/propietarios/editar/@prop.Id" class="btn btn-sm btn-outline-info" style="border-color: var(--border-glass); color: var(--text-primary);">Editar</a>
                                <button class="btn btn-sm btn-outline-danger" style="margin-left: 5px;" @onclick="() => ConfirmDelete(prop.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="text-secondary">Página @propietariosResponse.PageIndex de @propietariosResponse.TotalPages (@propietariosResponse.TotalCount registros)</span>
            <div>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!propietariosResponse.HasPreviousPage)" @onclick="PreviousPage">Anterior</button>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!propietariosResponse.HasNextPage)" @onclick="NextPage">Siguiente</button>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--accent-danger); color: white;">
        @errorMessage
    </div>
}

@code {
    private PaginatedList<PropietarioDto>? propietariosResponse;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    
    private int currentPage = 1;
    private int pageSize = 10;
    private string searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            propietariosResponse = await PropietarioService.GetAllAsync(currentPage, pageSize, searchTerm);
        }
        catch (Exception)
        {
            errorMessage = "Error de conexión al cargar clientes.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSearchChanged()
    {
        currentPage = 1;
        await LoadDataAsync();
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await LoadDataAsync();
    }

    private async Task PreviousPage()
    {
        if (propietariosResponse?.HasPreviousPage == true)
        {
            currentPage--;
            await LoadDataAsync();
        }
    }

    private async Task NextPage()
    {
        if (propietariosResponse?.HasNextPage == true)
        {
            currentPage++;
            await LoadDataAsync();
        }
    }

    private async Task ConfirmDelete(string id)
    {
        // Ideally show a modal, but for simplicity we'll logic here or use JS interop
        // Implementación rápida de borrado para el CRUD
        bool confirmed = true; // In real life: await JS.InvokeAsync<bool>("confirm", "Seguro?");
        if (confirmed)
        {
            var result = await PropietarioService.DeleteAsync(id);
            if (result)
                await LoadDataAsync();
            else
                errorMessage = "No se pudo eliminar el cliente.";
        }
    }
}
