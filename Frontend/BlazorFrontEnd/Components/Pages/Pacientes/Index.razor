@page "/pacientes"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject PacienteService PacienteService
@inject CatalogoService CatalogoService
@inject NavigationManager Navigation

<PageTitle>Mascotas / Pacientes</PageTitle>

<div class="d-flex justify-content-between align-items-center" style="margin-bottom: var(--sp-lg);">
    <div>
        <h2 style="font-weight: 700; margin: 0;">Registro de Pacientes</h2>
        <p class="text-secondary" style="margin: 0;">Gestión de mascotas y su historial clínico</p>
    </div>
    <a href="/pacientes/nuevo" class="btn-primary-glass" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 20px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Nuevo Paciente
    </a>
</div>

<div class="glass-card">
    <div style="margin-bottom: var(--sp-md);">
        <h4 style="margin: 0 0 12px 0;">Lista de Mascotas</h4>

        <!-- Filtros -->
        <div class="d-flex flex-wrap align-items-end gap-3" style="margin-bottom: 12px;">
            <div style="flex: 1; min-width: 200px;">
                <label class="text-secondary" style="font-size: 0.78rem; margin-bottom: 4px; display: block;">Nombre de mascota o dueño</label>
                <input type="text" @bind-value="searchTerm" @bind-value:after="OnFilterChanged" class="form-control form-control-sm"
                       placeholder="Buscar..."
                       style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: white;" />
            </div>
            <div style="min-width: 150px;">
                <label class="text-secondary" style="font-size: 0.78rem; margin-bottom: 4px; display: block;">Especie</label>
                <select @bind="filtroEspecie" @bind:after="OnFilterChanged" class="form-select form-select-sm"
                        style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: white;">
                    <option value="">Todas</option>
                    @if (especiesDisponibles != null)
                    {
                        @foreach (var esp in especiesDisponibles)
                        {
                            <option value="@esp.Nombre">@esp.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div style="min-width: 140px;">
                <label class="text-secondary" style="font-size: 0.78rem; margin-bottom: 4px; display: block;">Estado</label>
                <select @bind="filtroEstado" @bind:after="OnFilterChanged" class="form-select form-select-sm"
                        style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: white;">
                    <option value="Activo">Activos</option>
                    <option value="Inactivo">Inactivos</option>
                    <option value="">Todos</option>
                </select>
            </div>
            @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(filtroEspecie) || filtroEstado != "Activo")
            {
                <button class="btn btn-sm btn-outline-secondary" style="height: 31px; border-color: var(--border-glass); color: var(--text-secondary);" @onclick="ClearFilters">
                    Limpiar filtros
                </button>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <p class="text-secondary">Cargando datos...</p>
    }
    else if (filteredItems == null || !filteredItems.Any())
    {
        <p class="text-secondary">No se encontraron mascotas con los filtros aplicados.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover" style="background: transparent;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-glass);">
                        <th>Paciente</th>
                        <th>Especie / Raza</th>
                        <th>Propietario (Dueño)</th>
                        <th>Edad / Sexo</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pac in filteredItems)
                    {
                        <tr style="border-bottom: 1px solid var(--border-glass);">
                            <td>
                                <strong>@pac.Nombre</strong>
                            </td>
                            <td>
                                @pac.EspecieNombre
                                @if(!string.IsNullOrEmpty(pac.RazaNombre)) { <br/><small class="text-secondary">@pac.RazaNombre</small> }
                            </td>
                            <td>
                                <a href="/propietarios/editar/@pac.PropietarioId" style="color: var(--accent-primary); text-decoration: none;">@pac.PropietarioNombre</a>
                            </td>
                            <td>
                                @pac.EdadEnAnios años <br/> <small class="text-secondary">@(pac.Sexo == "M" ? "Macho" : pac.Sexo == "H" ? "Hembra" : "Desconocido")</small>
                            </td>
                            <td>
                                @if(pac.Activo) { <span style="color: var(--accent-primary);">Activo</span> }
                                else { <span style="color: var(--accent-danger);">Inactivo</span> }
                            </td>
                            <td class="text-end">
                                <a href="/pacientes/editar/@pac.Id" class="btn btn-sm btn-outline-info" style="border-color: var(--border-glass); color: var(--text-primary);">Editar</a>
                                <button class="btn btn-sm btn-outline-danger" style="margin-left: 5px;" @onclick="() => ConfirmDelete(pac.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="text-secondary">
                Mostrando @filteredItems.Count de @pacientesResponse?.TotalCount registros
                @if (pacientesResponse != null)
                {
                    <text> (Página @pacientesResponse.PageIndex de @pacientesResponse.TotalPages)</text>
                }
            </span>
            <div>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(pacientesResponse?.HasPreviousPage != true)" @onclick="PreviousPage">Anterior</button>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(pacientesResponse?.HasNextPage != true)" @onclick="NextPage">Siguiente</button>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--accent-danger); color: white;">
        @errorMessage
    </div>
}

@code {
    private PaginatedList<PacienteDto>? pacientesResponse;
    private List<PacienteDto>? filteredItems;
    private List<EspecieDto>? especiesDisponibles;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    
    private int currentPage = 1;
    private int pageSize = 50; // Load more to allow client-side filtering
    private string searchTerm = string.Empty;
    private string filtroEspecie = string.Empty;
    private string filtroEstado = "Activo"; // Default: only active

    protected override async Task OnInitializedAsync()
    {
        await LoadEspeciesAsync();
        await LoadDataAsync();
    }

    private async Task LoadEspeciesAsync()
    {
        try
        {
            especiesDisponibles = await CatalogoService.GetEspeciesActivasAsync();
        }
        catch { /* ignore */ }
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            pacientesResponse = await PacienteService.GetAllAsync(currentPage, pageSize, searchTerm);
            ApplyClientFilters();
        }
        catch (Exception)
        {
            errorMessage = "Error de conexión al cargar pacientes.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyClientFilters()
    {
        if (pacientesResponse?.Items == null)
        {
            filteredItems = null;
            return;
        }

        IEnumerable<PacienteDto> items = pacientesResponse.Items;

        // Filter by Estado
        if (filtroEstado == "Activo")
            items = items.Where(p => p.Activo);
        else if (filtroEstado == "Inactivo")
            items = items.Where(p => !p.Activo);

        // Filter by Especie
        if (!string.IsNullOrEmpty(filtroEspecie))
            items = items.Where(p => p.EspecieNombre == filtroEspecie);

        filteredItems = items.ToList();
    }

    private async Task OnFilterChanged()
    {
        currentPage = 1;
        await LoadDataAsync();
    }

    private async Task ClearFilters()
    {
        searchTerm = string.Empty;
        filtroEspecie = string.Empty;
        filtroEstado = "Activo";
        currentPage = 1;
        await LoadDataAsync();
    }

    private async Task PreviousPage()
    {
        if (pacientesResponse?.HasPreviousPage == true)
        {
            currentPage--;
            await LoadDataAsync();
        }
    }

    private async Task NextPage()
    {
        if (pacientesResponse?.HasNextPage == true)
        {
            currentPage++;
            await LoadDataAsync();
        }
    }

    private async Task ConfirmDelete(string id)
    {
        bool confirmed = true; 
        if (confirmed)
        {
            var result = await PacienteService.DeleteAsync(id);
            if (result) await LoadDataAsync();
            else errorMessage = "No se pudo eliminar el paciente.";
        }
    }
}
