@page "/historial-clinico/nueva-consulta/{PacienteId}"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject HistorialClinicoService HistorialService
@inject PacienteService PacienteService
@inject PersonalService PersonalService
@inject NavigationManager Navigation

<PageTitle>Registrar Consulta - Historial Clínico</PageTitle>

<div class="glass-card" style="max-width: 800px; margin: auto; margin-top:20px;">
    <h4>Nueva Consulta (@pacienteNombre)</h4>
    <hr class="border-secondary" />

    <EditForm Model="model" OnValidSubmit="HandleSave">
        <DataAnnotationsValidator />
        
        <div class="row mb-3">
            <div class="col-md-6">
                <label>Fecha (*)</label>
                <InputDate @bind-Value="model.Fecha" class="form-control bg-dark text-light border-secondary" />
            </div>
            <div class="col-md-6">
                <label>Veterinario Tratante (*)</label>
                <InputSelect @bind-Value="model.Veterinario" class="form-select bg-dark text-light border-secondary">
                    <option value="">Seleccione...</option>
                    @foreach (var v in vets)
                    {
                        <option value="@v.NombreCompleto">@v.NombreCompleto</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => model.Veterinario)" class="text-danger" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label>Peso (kg)</label>
                <InputNumber @bind-Value="model.Peso" class="form-control bg-dark text-light border-secondary" />
            </div>
            <div class="col-md-6">
                <label>Temp (°C)</label>
                <InputNumber @bind-Value="model.Temperatura" class="form-control bg-dark text-light border-secondary" />
            </div>
        </div>

        <div class="mb-3">
            <label>Motivo de Consulta (*)</label>
            <InputText @bind-Value="model.Motivo" class="form-control bg-dark text-light border-secondary" />
            <ValidationMessage For="@(() => model.Motivo)" class="text-danger" />
        </div>

        <div class="mb-3">
            <label>Síntomas reportados</label>
            <InputTextArea @bind-Value="model.Sintomas" class="form-control bg-dark text-light border-secondary" rows="2" />
        </div>

        <div class="mb-3">
            <label>Diagnóstico (Presuntivo o Definitivo)</label>
            <InputTextArea @bind-Value="model.Diagnostico" class="form-control bg-dark text-light border-secondary" rows="2" />
        </div>

        <div class="mb-3">
            <label>Indicaciones al Propietario</label>
            <InputTextArea @bind-Value="model.Indicaciones" class="form-control bg-dark text-light border-secondary" rows="3" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger p-2 mt-2">@errorMessage</div>
        }

        <div class="d-flex justify-content-end mt-4 gap-2">
            <button type="button" class="btn btn-outline-secondary text-light" @onclick="GoBack">Cancelar</button>
            <button type="submit" class="btn-primary-glass" disabled="@isSaving">Guardar Consulta</button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter]
    public string PacienteId { get; set; } = string.Empty;

    private HistorialClinicoDto model = new() { Fecha = DateTime.Today };
    private string pacienteNombre = "Cargando...";
    private bool isSaving;
    private string errorMessage = string.Empty;
    private List<VeterinarioDto> vets = new();

    protected override async Task OnInitializedAsync()
    {
        model.PacienteId = PacienteId;
        var p = await PacienteService.GetByIdAsync(PacienteId);
        if(p != null) {
            pacienteNombre = p.Nombre;
            model.PacienteNombre = p.Nombre;
        }

        var vRes = await PersonalService.GetVeterinariosActivosAsync();
        if(vRes != null) vets = vRes;
    }

    private async Task HandleSave()
    {
        isSaving = true;
        if(await HistorialService.CreateAsync(model))
        {
            GoBack();
        }
        else
        {
            errorMessage = "No se pudo guardar la consulta.";
            isSaving = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo($"/historial-clinico/paciente/{PacienteId}");
}
