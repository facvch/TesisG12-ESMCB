@page "/usuarios/nuevo"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject UsuarioService UsuarioService
@inject NavigationManager Navigation
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject BlazorFrontEnd.Auth.TokenStorageService TokenStorage

<PageTitle>Registrar Nuevo Usuario</PageTitle>

<div class="glass-card" style="max-width: 600px; margin: auto; margin-top: 30px;">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-link" style="color: var(--text-secondary); padding: 0; margin-right: 15px;" @onclick="GoBack">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
        </button>
        <h3 class="m-0" style="font-weight: 700;">Alta de Operador</h3>
    </div>

    @if (isLoading)
    {
        <p class="text-secondary text-center">Cargando permisos y roles...</p>
    }
    else
    {
        <EditForm Model="model" OnValidSubmit="HandleSave">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label>Nombre Completo (*)</label>
                <InputText @bind-Value="model.NombreCompleto" class="form-control bg-dark text-light border-secondary" placeholder="Ej: Dr. Juan Pérez" />
                <ValidationMessage For="@(() => model.NombreCompleto)" class="text-danger" />
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label>Nombre de Usuario (Alias) (*)</label>
                    <InputText @bind-Value="model.NombreUsuario" class="form-control bg-dark text-light border-secondary" placeholder="Ej: jperez" />
                    <ValidationMessage For="@(() => model.NombreUsuario)" class="text-danger" />
                </div>
                <div class="col-md-6">
                    <label>Rol Interno (*)</label>
                    <InputSelect @bind-Value="model.RolId" class="form-select bg-dark text-light border-secondary">
                        <option value="0">Seleccione un cargo...</option>
                        @foreach(var r in roles)
                        {
                            <option value="@r.Id">@r.Nombre</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => model.RolId)" class="text-danger" />
                </div>
            </div>

            <div class="mb-3">
                <label>Correo Electrónico (*)</label>
                <InputText @bind-Value="model.Email" class="form-control bg-dark text-light border-secondary" type="email" placeholder="jperez@veterinaria.com" />
                <ValidationMessage For="@(() => model.Email)" class="text-danger" />
            </div>

            <div class="mb-4">
                <label>Contraseña Provisoria (*)</label>
                <InputText @bind-Value="model.Password" class="form-control bg-dark text-light border-secondary" type="password" />
                <ValidationMessage For="@(() => model.Password)" class="text-danger" />
                <small class="text-secondary">Debe contener al menos 6 caracteres.</small>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger p-2">@errorMessage</div>
            }

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="button" class="btn btn-outline-secondary text-light" @onclick="GoBack">Cancelar</button>
                <button type="submit" class="btn-primary-glass" disabled="@isSaving">
                    @if(isSaving) { <span>Creando Cuenta...</span> } else { <span>Conceder Acceso</span> }
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    private RegisterRequest model = new();
    private List<RolDto> roles = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SyncTokenAsync();
            isLoading = true;
            StateHasChanged();
            var r = await UsuarioService.GetRolesAsync();
            if(r != null) roles = r;
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SyncTokenAsync()
    {
        try
        {
            var token = await LocalStorage.GetItemAsync<string>("authToken");
            if (!string.IsNullOrWhiteSpace(token))
                TokenStorage.SetToken(token);
        }
        catch { }
    }

    private async Task HandleSave()
    {
        if(model.RolId == 0) {
            errorMessage = "Debe asignar un Rol válido al usuario para continuar.";
            return; 
        }

        isSaving = true;
        errorMessage = "";

        try
        {
            var res = await UsuarioService.RegisterUserAsync(model);
            if(res) {
                Navigation.NavigateTo("/usuarios");
            } else {
                errorMessage = "Hubo un error al registrar el usuario. El alias o email podrían estar ya en uso o no cuenta con los permisos de Administrador para realizar esta acción.";
            }
        }
        catch(Exception)
        {
            errorMessage = "Excepción interna comunicándose con AuthController.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/usuarios");
}
