@page "/veterinarios"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject VeterinarioService VeterinarioService
@inject NavigationManager Navigation

<PageTitle>Directorio Médico</PageTitle>

<div class="d-flex justify-content-between align-items-center" style="margin-bottom: var(--sp-lg);">
    <div>
        <h2 style="font-weight: 700; margin: 0;">Cuerpo Médico Veterinario</h2>
        <p class="text-secondary" style="margin: 0;">Gestión de información de contacto y especialidades</p>
    </div>
    <a href="/veterinarios/nuevo" class="btn-primary-glass" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 20px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Registrar Profesional
    </a>
</div>

<div class="glass-card">
    @if (isLoading)
    {
        <p class="text-secondary">Cargando directorio de profesionales...</p>
    }
    else if (veterinarios == null || !veterinarios.Any())
    {
        <p class="text-secondary">No hay profesionales registrados actualmente.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover" style="background: transparent;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-glass);">
                        <th>Dr./Dra.</th>
                        <th>Matrícula</th>
                        <th>Especialidad</th>
                        <th>Contacto</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in veterinarios)
                    {
                        <tr style="border-bottom: 1px solid var(--border-glass);">
                            <td>
                                <strong>@v.NombreCompleto</strong>
                            </td>
                            <td><span class="badge bg-secondary">MP: @v.Matricula</span></td>
                            <td class="text-info">@(string.IsNullOrEmpty(v.Especialidad) ? "Clínica General" : v.Especialidad)</td>
                            <td>
                                <div class="small">
                                    📞 @v.Telefono<br/>
                                    ✉️ @v.Email
                                </div>
                            </td>
                            <td class="text-end">
                                <a href="/veterinarios/editar/@v.Id" class="btn btn-sm btn-outline-info" style="border-color: var(--border-glass); color: var(--text-primary);">Editar</a>
                                <button class="btn btn-sm btn-outline-danger ms-2" @onclick="() => ConfirmarDelete(v.Id)">Dar de Baja</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--accent-danger); color: white;">
        @errorMessage
    </div>
}

@code {
    private List<VeterinarioDto>? veterinarios;
    private bool isLoading = true;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            var paged = await VeterinarioService.GetAllAsync(true);
            if(paged != null && paged.Items != null) {
                veterinarios = paged.Items.ToList();
            }
        }
        catch (Exception)
        {
            errorMessage = "Error de conexión al cargar el directorio médico.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ConfirmarDelete(string id)
    {
        bool confirm = true; 
        if(confirm)
        {
            var exito = await VeterinarioService.DeleteAsync(id);
            if(exito) await LoadDataAsync();
            else errorMessage = "Error al dar de baja al profesional. Puede tener consultas asignadas.";
        }
    }
}
