@page "/inventario/productos"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject ProductoService ProductoService
@inject CatalogoInventarioService CatalogoService
@inject NavigationManager Navigation

<PageTitle>Productos - Inventario</PageTitle>

<div class="d-flex justify-content-between align-items-center" style="margin-bottom: var(--sp-lg);">
    <div class="d-flex align-items-center">
        <button class="btn btn-link" style="color: var(--text-secondary); padding: 0; margin-right: 15px;" @onclick="GoBack">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
        </button>
        <div>
            <h2 style="font-weight: 700; margin: 0;">Gestión de Productos</h2>
            <p class="text-secondary" style="margin: 0;">Inventario general con control de stock</p>
        </div>
    </div>
    <a href="/inventario/productos/nuevo" class="btn-primary-glass" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 20px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Nuevo Producto
    </a>
</div>

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center" style="margin-bottom: var(--sp-sm);">
        <h4 style="margin: 0;">Lista de Productos</h4>
        <input type="text" @bind-value="searchTerm" @bind-value:after="OnSearchChanged" class="form-control" placeholder="Buscar por nombre o código..." style="width: 300px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: white;" />
    </div>

    @* ── Barra de Filtros ── *@
    <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: var(--sp-md); padding: 10px 14px; background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass); border-radius: 8px;">
        <div style="display: flex; align-items: center; gap: 6px;">
            <label style="color: var(--text-secondary); font-size: 0.8rem; white-space: nowrap;">Categoría:</label>
            <select @bind="filterCategoria" @bind:after="ApplyFilters" class="form-select form-select-sm bg-dark text-light border-secondary" style="width: 160px; font-size: 0.85rem;">
                <option value="0">Todas</option>
                @foreach (var c in categorias)
                {
                    <option value="@c.Id">@c.Nombre</option>
                }
            </select>
        </div>
        <div style="display: flex; align-items: center; gap: 6px;">
            <label style="color: var(--text-secondary); font-size: 0.8rem; white-space: nowrap;">Marca:</label>
            <select @bind="filterMarca" @bind:after="ApplyFilters" class="form-select form-select-sm bg-dark text-light border-secondary" style="width: 160px; font-size: 0.85rem;">
                <option value="0">Todas</option>
                @foreach (var m in marcas)
                {
                    <option value="@m.Id">@m.Nombre</option>
                }
            </select>
        </div>
        <div style="display: flex; align-items: center; gap: 6px;">
            <label style="color: var(--text-secondary); font-size: 0.8rem; white-space: nowrap;">Estado:</label>
            <select @bind="filterEstado" @bind:after="ApplyFilters" class="form-select form-select-sm bg-dark text-light border-secondary" style="width: 130px; font-size: 0.85rem;">
                <option value="todos">Todos</option>
                <option value="activo">Activos</option>
                <option value="inactivo">Inactivos</option>
            </select>
        </div>
        <div style="display: flex; align-items: center; gap: 6px;">
            <label class="form-check-label" style="color: var(--text-secondary); font-size: 0.8rem; cursor: pointer; white-space: nowrap;" for="chkStockBajo">
                <input type="checkbox" id="chkStockBajo" @bind="filterStockBajo" @bind:after="ApplyFilters" class="form-check-input" style="margin-right: 4px;" />
                Solo Stock Bajo
            </label>
        </div>
        @if (HasActiveFilters)
        {
            <button class="btn btn-sm btn-outline-secondary text-light" style="font-size: 0.8rem; padding: 2px 10px;" @onclick="ClearFilters">✕ Limpiar</button>
        }
    </div>

    @if (isLoading)
    {
        <p class="text-secondary">Cargando productos...</p>
    }
    else if (filteredItems == null || !filteredItems.Any())
    {
        <p class="text-secondary">No se encontraron productos con los filtros aplicados.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover" style="background: transparent;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-glass);">
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Marca</th>
                        <th style="text-align: right;">P. Compra</th>
                        <th style="text-align: right;">P. Venta</th>
                        <th style="text-align: center;">Stock</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in filteredItems!)
                    {
                        <tr style="border-bottom: 1px solid var(--border-glass);">
                            <td>
                                <strong>@p.Nombre</strong>
                                @if(!string.IsNullOrEmpty(p.CodigoBarras))
                                {
                                    <br/><small class="text-secondary">@p.CodigoBarras</small>
                                }
                            </td>
                            <td>@p.CategoriaNombre</td>
                            <td>@p.MarcaNombre</td>
                            <td style="text-align: right;">$@p.PrecioCompra.ToString("N2")</td>
                            <td style="text-align: right;">$@p.PrecioVenta.ToString("N2")</td>
                            <td style="text-align: center;">
                                @if(p.StockBajo)
                                {
                                    <span style="background: rgba(239,68,68,0.3); color: #ff6b6b; padding: 2px 10px; border-radius: 12px; font-size: 0.85rem; font-weight: 600;">
                                        @p.StockActual / @p.StockMinimo
                                    </span>
                                }
                                else
                                {
                                    <span style="background: rgba(34,197,94,0.2); color: #4ade80; padding: 2px 10px; border-radius: 12px; font-size: 0.85rem;">
                                        @p.StockActual
                                    </span>
                                }
                            </td>
                            <td>
                                @if(p.Activo) { <span style="color: var(--accent-primary);">Activo</span> }
                                else { <span style="color: var(--accent-danger);">Inactivo</span> }
                            </td>
                            <td class="text-end" style="white-space: nowrap;">
                                <a href="/inventario/productos/editar/@p.Id" class="btn btn-sm btn-outline-info" style="border-color: var(--border-glass); color: var(--text-primary);">Editar</a>
                                <button class="btn btn-sm btn-outline-success" style="margin-left: 4px;" @onclick="() => ShowStockModal(p)">Stock</button>
                                <button class="btn btn-sm btn-outline-danger" style="margin-left: 4px;" @onclick="() => ConfirmDelete(p.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="text-secondary">Pagina @productosResponse.PageIndex de @productosResponse.TotalPages (@productosResponse.TotalCount registros)</span>
            <div>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!productosResponse.HasPreviousPage)" @onclick="PreviousPage">Anterior</button>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!productosResponse.HasNextPage)" @onclick="NextPage">Siguiente</button>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--accent-danger); color: white;">
        @errorMessage
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-3" style="background: rgba(34, 197, 94, 0.2); border: 1px solid #4ade80; color: white;">
        @successMessage
    </div>
}

@* ── Modal de Movimiento de Stock ── *@
@if (showStockModal && selectedProducto != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 1000;" @onclick="CloseStockModal">
        <div class="glass-card" style="width: 450px; max-width: 95vw;" @onclick:stopPropagation>
            <h4 style="margin-bottom: var(--sp-md);">Movimiento de Stock — @selectedProducto.Nombre</h4>
            <p class="text-secondary">Stock actual: <strong style="color: white;">@selectedProducto.StockActual</strong></p>

            <div style="margin-bottom: var(--sp-sm);">
                <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Tipo de Movimiento</label>
                <select @bind="stockTipo" class="form-select bg-dark text-light border-secondary">
                    <option value="entrada">Entrada (Ingreso)</option>
                    <option value="salida">Salida (Egreso)</option>
                </select>
            </div>

            <div style="margin-bottom: var(--sp-sm);">
                <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Cantidad (*)</label>
                <input type="number" @bind="stockCantidad" class="form-control bg-dark text-light border-secondary" min="1" />
            </div>

            <div style="margin-bottom: var(--sp-sm);">
                <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Motivo</label>
                <input type="text" @bind="stockMotivo" class="form-control bg-dark text-light border-secondary" placeholder="Ej: Compra a proveedor, Venta, Rotura..." />
            </div>

            @if (!string.IsNullOrEmpty(stockError))
            {
                <div class="alert alert-danger mt-2" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--accent-danger); color: white; font-size: 0.9rem;">
                    @stockError
                </div>
            }

            <div class="d-flex justify-content-end mt-3" style="gap: 10px;">
                <button class="btn btn-outline-secondary text-light" @onclick="CloseStockModal">Cancelar</button>
                <button class="btn-primary-glass" disabled="@isSavingStock" @onclick="HandleStockMovement">
                    @if(isSavingStock) { <span>Procesando...</span> } else { <span>Confirmar</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedList<ProductoDto>? productosResponse;
    private List<ProductoDto>? filteredItems;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private int currentPage = 1;
    private int pageSize = 15;
    private string searchTerm = string.Empty;

    // Filtros
    private int filterCategoria;
    private int filterMarca;
    private string filterEstado = "todos";
    private bool filterStockBajo;
    private List<CategoriaDto> categorias = new();
    private List<MarcaDto> marcas = new();
    private bool HasActiveFilters => filterCategoria > 0 || filterMarca > 0 || filterEstado != "todos" || filterStockBajo;

    // Stock modal
    private bool showStockModal;
    private ProductoDto? selectedProducto;
    private string stockTipo = "entrada";
    private int stockCantidad = 1;
    private string stockMotivo = string.Empty;
    private string stockError = string.Empty;
    private bool isSavingStock;

    protected override async Task OnInitializedAsync()
    {
        // Cargar catálogos para filtros en paralelo con los datos
        var catTask = CatalogoService.GetCategoriasAsync();
        var marTask = CatalogoService.GetMarcasAsync();
        var loadTask = LoadDataAsync();
        await Task.WhenAll(catTask, marTask, loadTask);
        categorias = catTask.Result ?? new();
        marcas = marTask.Result ?? new();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            productosResponse = await ProductoService.GetAllAsync(currentPage, pageSize, searchTerm);
            ApplyFiltersInternal();
        }
        catch (Exception)
        {
            errorMessage = "Error de conexión al cargar productos.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFiltersInternal()
    {
        if (productosResponse?.Items == null) { filteredItems = null; return; }

        IEnumerable<ProductoDto> items = productosResponse.Items;

        if (filterCategoria > 0)
            items = items.Where(p => p.CategoriaId == filterCategoria);
        if (filterMarca > 0)
            items = items.Where(p => p.MarcaId == filterMarca);
        if (filterEstado == "activo")
            items = items.Where(p => p.Activo);
        else if (filterEstado == "inactivo")
            items = items.Where(p => !p.Activo);
        if (filterStockBajo)
            items = items.Where(p => p.StockBajo);

        filteredItems = items.ToList();
    }

    private void ApplyFilters() => ApplyFiltersInternal();

    private async Task ClearFilters()
    {
        filterCategoria = 0;
        filterMarca = 0;
        filterEstado = "todos";
        filterStockBajo = false;
        ApplyFiltersInternal();
    }

    private async Task OnSearchChanged()
    {
        currentPage = 1;
        await LoadDataAsync();
    }

    private async Task PreviousPage()
    {
        if (productosResponse?.HasPreviousPage == true)
        {
            currentPage--;
            await LoadDataAsync();
        }
    }

    private async Task NextPage()
    {
        if (productosResponse?.HasNextPage == true)
        {
            currentPage++;
            await LoadDataAsync();
        }
    }

    private async Task ConfirmDelete(string id)
    {
        var result = await ProductoService.DeleteAsync(id);
        if (result) await LoadDataAsync();
        else errorMessage = "No se pudo eliminar el producto.";
    }

    // ── Stock Modal ──
    private void ShowStockModal(ProductoDto p)
    {
        selectedProducto = p;
        stockTipo = "entrada";
        stockCantidad = 1;
        stockMotivo = string.Empty;
        stockError = string.Empty;
        showStockModal = true;
    }

    private void CloseStockModal()
    {
        showStockModal = false;
        selectedProducto = null;
    }

    private async Task HandleStockMovement()
    {
        if (selectedProducto == null) return;
        if (stockCantidad <= 0) { stockError = "La cantidad debe ser mayor a 0."; return; }

        isSavingStock = true;
        stockError = string.Empty;

        var req = new MovimientoStockRequest { Cantidad = stockCantidad, Motivo = stockMotivo };
        bool ok;

        if (stockTipo == "entrada")
            ok = await ProductoService.EntradaStockAsync(selectedProducto.Id, req);
        else
            ok = await ProductoService.SalidaStockAsync(selectedProducto.Id, req);

        isSavingStock = false;

        if (ok)
        {
            successMessage = $"Movimiento de stock ({stockTipo}) registrado correctamente.";
            CloseStockModal();
            await LoadDataAsync();
            // Auto-clear success after render
            _ = Task.Delay(4000).ContinueWith(_ => { successMessage = string.Empty; InvokeAsync(StateHasChanged); });
        }
        else
        {
            stockError = stockTipo == "salida"
                ? "Stock insuficiente o error al procesar la salida."
                : "Error al procesar la entrada de stock.";
        }
    }

    private void GoBack() => Navigation.NavigateTo("/inventario");
}
