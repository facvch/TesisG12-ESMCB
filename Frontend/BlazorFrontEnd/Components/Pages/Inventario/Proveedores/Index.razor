@page "/inventario/proveedores"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject CatalogoInventarioService CatalogoService
@inject NavigationManager Navigation

<PageTitle>Proveedores</PageTitle>

<div class="d-flex justify-content-between align-items-center" style="margin-bottom: var(--sp-lg);">
    <div class="d-flex align-items-center">
        <button class="btn btn-link" style="color: var(--text-secondary); padding: 0; margin-right: 15px;" @onclick="GoBack">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
        </button>
        <div>
            <h2 style="font-weight: 700; margin: 0;">Proveedores</h2>
            <p class="text-secondary" style="margin: 0;">Directorio de agentes comerciales de suministro</p>
        </div>
    </div>
    <a href="/inventario/proveedores/nuevo" class="btn-primary-glass" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 20px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Nuevo Proveedor
    </a>
</div>

<div class="glass-card">
    @if (isLoading)
    {
        <p class="text-secondary">Cargando proveedores...</p>
    }
    else if (Items == null || !Items.Any())
    {
        <p class="text-secondary">No hay proveedores registrados. Comienza agregando uno.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover" style="background: transparent;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-glass);">
                        <th>ID</th>
                        <th>Razón Social</th>
                        <th>CUIT</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Activo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in Items)
                    {
                        <tr style="border-bottom: 1px solid var(--border-glass);">
                            <td><span class="text-secondary">#@i.Id</span></td>
                            <td><strong>@i.RazonSocial</strong></td>
                            <td>@i.Cuit</td>
                            <td>@i.Telefono</td>
                            <td><a href="mailto:@i.Email" class="text-light">@i.Email</a></td>
                            <td>
                                @if(i.Activo) { <span class="badge bg-success">Sí</span> }
                                else { <span class="badge bg-danger">No</span> }
                            </td>
                            <td class="text-end">
                                <a href="/inventario/proveedores/editar/@i.Id" class="btn btn-sm btn-outline-info" style="border-color: var(--border-glass); color: var(--text-primary);">Editar</a>
                                <button class="btn btn-sm btn-outline-danger" style="margin-left: 5px;" @onclick="() => ConfirmDelete(i.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--accent-danger); color: white;">
        @errorMessage
    </div>
}

@code {
    private List<ProveedorDto>? Items;
    private bool isLoading = true;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            Items = await CatalogoService.GetProveedoresAsync();
        }
        catch (Exception)
        {
            errorMessage = "Error de conexión al cargar los proveedores.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/inventario");

    private async Task ConfirmDelete(string id)
    {
        bool confirmed = true;
        if (confirmed)
        {
            var result = await CatalogoService.DeleteProveedorAsync(id);
            if (result) await LoadDataAsync();
            else errorMessage = "No se pudo eliminar el elemento. Podría tener dependencias.";
        }
    }
}
