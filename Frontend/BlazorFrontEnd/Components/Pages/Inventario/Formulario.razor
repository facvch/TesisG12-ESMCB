@page "/inventario/nuevo"
@page "/inventario/editar/{Id}"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject ProductoService ProductoService
@inject CatalogoInventarioService CatalogoService
@inject NavigationManager Navigation

<PageTitle>@(isEdit ? "Ficha de Producto" : "Nuevo Producto")</PageTitle>

<div class="d-flex align-items-center" style="margin-bottom: var(--sp-lg);">
    <button class="btn btn-link" style="color: var(--text-secondary); padding: 0; margin-right: 15px;" @onclick="GoBack">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
    </button>
    <h2 style="font-weight: 700; margin: 0;">@(isEdit ? "Editar Producto" : "Nuevo Producto")</h2>
</div>

<div class="glass-card" style="max-width: 900px;">
    @if (isLoading)
    {
        <p class="text-secondary">Cargando dependencias de inventario...</p>
    }
    else
    {
        <EditForm Model="model" OnValidSubmit="HandleSave" FormName="productoForm">
            <DataAnnotationsValidator />
            
            <div class="row">
                <div class="col-md-8" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Nombre del Producto (*)</label>
                    <InputText @bind-Value="model.Nombre" class="form-control bg-dark text-light border-secondary" />
                    <ValidationMessage For="@(() => model.Nombre)" class="text-danger" />
                </div>
                
                <div class="col-md-4" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Código de Barras (*)</label>
                    <InputText @bind-Value="model.CodigoBarras" class="form-control bg-dark text-light border-secondary" disabled="@isEdit" />
                    <ValidationMessage For="@(() => model.CodigoBarras)" class="text-danger" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Categoría (*)</label>
                    <InputSelect @bind-Value="model.CategoriaId" class="form-select bg-dark text-light border-secondary">
                        <option value="0">Seleccione...</option>
                        @foreach (var c in categorias)
                        {
                            <option value="@c.Id">@c.Nombre</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => model.CategoriaId)" class="text-danger" />
                </div>
                
                <div class="col-md-4" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Marca</label>
                    <InputSelect @bind-Value="model.MarcaId" class="form-select bg-dark text-light border-secondary">
                        <option value="">(Opcional)</option>
                        @foreach (var m in marcas)
                        {
                            <option value="@m.Id">@m.Nombre</option>
                        }
                    </InputSelect>
                </div>
                
                <div class="col-md-4" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Proveedor Base</label>
                    <InputSelect @bind-Value="model.ProveedorId" class="form-select bg-dark text-light border-secondary">
                        <option value="">(Opcional)</option>
                        @foreach (var p in proveedores)
                        {
                            <option value="@p.Id">@p.RazonSocial</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="row">
                <div class="col-md-3" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Precio Costo ($)</label>
                    <InputNumber @bind-Value="model.PrecioCompra" class="form-control bg-dark text-light border-secondary" step="0.01" />
                    <ValidationMessage For="@(() => model.PrecioCompra)" class="text-danger" />
                </div>
                
                <div class="col-md-3" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Precio Venta ($)</label>
                    <InputNumber @bind-Value="model.PrecioVenta" class="form-control bg-dark text-light border-secondary" style="border-color: var(--accent-primary) !important; color: var(--accent-primary) !important;" step="0.01" />
                    <ValidationMessage For="@(() => model.PrecioVenta)" class="text-danger" />
                </div>

                <div class="col-md-3" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Stock Min. Alerta</label>
                    <InputNumber @bind-Value="model.StockMinimo" class="form-control bg-dark text-light border-secondary" />
                    <ValidationMessage For="@(() => model.StockMinimo)" class="text-danger" />
                </div>

                @if(!isEdit)
                {
                    <div class="col-md-3" style="margin-bottom: var(--sp-sm);">
                        <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Stock Inicial</label>
                        <InputNumber @bind-Value="model.StockActual" class="form-control bg-dark text-light border-secondary" />
                    </div>
                }
                else
                {
                    <div class="col-md-3" style="margin-bottom: var(--sp-sm);">
                        <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Stock Actual</label>
                        <input type="text" value="@model.StockActual" class="form-control bg-dark text-secondary border-secondary" disabled />
                    </div>
                }
            </div>

            <div class="row">
                <div class="col-12" style="margin-bottom: var(--sp-sm);">
                    <label class="form-label" style="color: var(--text-secondary); font-size: 0.875rem;">Descripción Corta</label>
                    <InputTextArea @bind-Value="model.Descripcion" class="form-control bg-dark text-light border-secondary" rows="2" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--accent-danger); color: white;">
                    @errorMessage
                </div>
            }

            <div class="d-flex justify-content-between mt-4">
                @if (isEdit)
                {
                    <div>
                        <button type="button" class="btn btn-outline-success btn-sm me-2" @onclick="AbrirModalEntrada">Ingreso de Mercadería</button>
                        <button type="button" class="btn btn-outline-warning btn-sm text-light" @onclick="AbrirModalSalida">Ajuste / Salida</button>
                    </div>
                }
                else
                {
                    <div></div>
                }

                <div style="gap: 10px;">
                    <button type="button" class="btn btn-outline-secondary text-light" @onclick="GoBack">Retornar</button>
                    <button type="submit" class="btn-primary-glass" disabled="@isSaving">
                        @if(isSaving) { <span>Guardando Producto...</span> } else { <span>Guardar en Catálogo</span> }
                    </button>
                </div>
            </div>
        </EditForm>
    }
</div>

@* Nota: En una app real, aquí abriríamos modales para Entrada/Salida rápida llamando a ProductoService.EntradaStockAsync y SalidaStockAsync *@

@code {
    [Parameter]
    public string? Id { get; set; }

    private ProductoDto model = new();
    private bool isEdit => !string.IsNullOrEmpty(Id);
    private bool isLoading = true;
    private bool isSaving;
    private string errorMessage = string.Empty;

    private List<CategoriaDto> categorias = new();
    private List<MarcaDto> marcas = new();
    private List<ProveedorDto> proveedores = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var resC = await CatalogoService.GetCategoriasAsync();
            if(resC != null) categorias = resC;

            var resM = await CatalogoService.GetMarcasAsync();
            if(resM != null) marcas = resM;

            var resP = await CatalogoService.GetProveedoresAsync();
            if(resP != null) proveedores = resP;

            if (isEdit)
            {
                var response = await ProductoService.GetByIdAsync(Id!);
                if (response != null) model = response;
                else errorMessage = "No se encontró el producto solicitado.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Error al comunicarse con la base de datos de catálogos.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSave()
    {
        if (model.CategoriaId == 0)
        {
            errorMessage = "Debe asignar una Categoría obligatoriamente.";
            return;
        }

        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            bool result;
            if (isEdit) 
                result = await ProductoService.UpdateAsync(Id!, model);
            else 
                result = await ProductoService.CreateAsync(model);

            if (result)
            {
                Navigation.NavigateTo("/inventario");
            }
            else
            {
                errorMessage = "Hubo un problema de validación en el Backend (Ej: Código de barras duplicado o Categoría inexistente).";
            }
        }
        catch (Exception)
        {
            errorMessage = "Excepción al enviar datos del producto.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void AbrirModalEntrada() { /* Mock JS Interop Model */ }
    private void AbrirModalSalida() { /* Mock JS Interop Model */ }

    private void GoBack() => Navigation.NavigateTo("/inventario");
}
