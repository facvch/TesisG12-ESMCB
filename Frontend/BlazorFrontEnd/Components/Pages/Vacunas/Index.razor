@page "/vacunas"
@using BlazorFrontEnd.Models
@using BlazorFrontEnd.Services
@inject VacunaService VacunaService
@inject NavigationManager Navigation

<PageTitle>Catálogo de Vacunas</PageTitle>

<div class="d-flex justify-content-between align-items-center" style="margin-bottom: var(--sp-lg);">
    <div>
        <h2 style="font-weight: 700; margin: 0;">Catálogo de Vacunas</h2>
        <p class="text-secondary" style="margin: 0;">Gestione las vacunas disponibles para aplicar en el plan sanitario</p>
    </div>
    <button class="btn-primary-glass" @onclick="ShowCreateForm">+ Nueva Vacuna</button>
</div>

@* ─── Formulario Crear/Editar ─── *@
@if (showForm)
{
    <div class="glass-card" style="margin-bottom: var(--sp-md);">
        <h5>@(isEditing ? "Editar Vacuna" : "Registrar Nueva Vacuna")</h5>
        <hr class="border-secondary" />

        <EditForm Model="formModel" OnValidSubmit="HandleSave">
            <DataAnnotationsValidator />

            <div class="row mb-3">
                <div class="col-md-4">
                    <label>Nombre (*)</label>
                    <InputText @bind-Value="formModel.Nombre" class="form-control bg-dark text-light border-secondary" placeholder="Ej: Séxtuple Canina" />
                    <ValidationMessage For="@(() => formModel.Nombre)" class="text-danger" />
                </div>
                <div class="col-md-4">
                    <label>Laboratorio</label>
                    <InputText @bind-Value="formModel.Laboratorio" class="form-control bg-dark text-light border-secondary" placeholder="Ej: Nobivac" />
                </div>
                <div class="col-md-4">
                    <label>Intervalo Dosis (días)</label>
                    <InputNumber @bind-Value="formModel.IntervaloDosisDias" class="form-control bg-dark text-light border-secondary" />
                    <small class="text-secondary">Dejar vacío si es dosis única</small>
                </div>
            </div>

            <div class="mb-3">
                <label>Descripción</label>
                <InputTextArea @bind-Value="formModel.Descripcion" class="form-control bg-dark text-light border-secondary" rows="2" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger p-2 mt-2">@errorMessage</div>
            }

            <div class="d-flex justify-content-end mt-3 gap-2">
                <button type="button" class="btn btn-outline-secondary text-light" @onclick="CancelForm">Cancelar</button>
                <button type="submit" class="btn-primary-glass" disabled="@isSaving">
                    @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    @(isEditing ? "Actualizar" : "Guardar")
                </button>
            </div>
        </EditForm>
    </div>
}

@* ─── Tabla ─── *@
<div class="glass-card">
    @if (isLoading)
    {
        <p class="text-secondary">Cargando catálogo de vacunas...</p>
    }
    else if (vacunas == null || !vacunas.Any())
    {
        <p class="text-secondary">No hay vacunas registradas en el catálogo. Haga clic en "+ Nueva Vacuna" para agregar.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover" style="background: transparent;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-glass);">
                        <th>Nombre</th>
                        <th>Laboratorio</th>
                        <th>Descripción</th>
                        <th class="text-center">Intervalo (días)</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in vacunas)
                    {
                        <tr style="border-bottom: 1px solid var(--border-glass);">
                            <td><strong class="text-light">@v.Nombre</strong></td>
                            <td class="text-secondary">@v.Laboratorio</td>
                            <td class="text-secondary" style="max-width: 300px;">@v.Descripcion</td>
                            <td class="text-center">
                                @if (v.IntervaloDosisDias.HasValue)
                                {
                                    <span class="text-info">@v.IntervaloDosisDias días</span>
                                }
                                else
                                {
                                    <span class="text-secondary">Dosis única</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (v.Activo)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactiva</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-info" @onclick="() => EditVacuna(v)" title="Editar">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:14px;height:14px;">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z" />
                                    </svg>
                                </button>
                                @if (v.Activo)
                                {
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DesactivarVacuna(v.Id)" title="Desactivar">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:14px;height:14px;">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                        </svg>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-secondary mt-2" style="font-size: 0.85rem;">Total: @vacunas.Count vacunas</p>
    }
</div>

@code {
    private List<VacunaDto>? vacunas;
    private bool isLoading = true;
    private bool showForm;
    private bool isEditing;
    private bool isSaving;
    private string errorMessage = string.Empty;
    private VacunaDto formModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        vacunas = await VacunaService.GetAllAsync(soloActivas: false);
        isLoading = false;
    }

    private void ShowCreateForm()
    {
        formModel = new VacunaDto { Activo = true };
        isEditing = false;
        showForm = true;
        errorMessage = string.Empty;
    }

    private void EditVacuna(VacunaDto vacuna)
    {
        formModel = new VacunaDto
        {
            Id = vacuna.Id,
            Nombre = vacuna.Nombre,
            Descripcion = vacuna.Descripcion,
            Laboratorio = vacuna.Laboratorio,
            IntervaloDosisDias = vacuna.IntervaloDosisDias,
            Activo = vacuna.Activo
        };
        isEditing = true;
        showForm = true;
        errorMessage = string.Empty;
    }

    private void CancelForm()
    {
        showForm = false;
        errorMessage = string.Empty;
    }

    private async Task HandleSave()
    {
        isSaving = true;
        errorMessage = string.Empty;

        bool success;
        if (isEditing)
        {
            success = await VacunaService.UpdateAsync(formModel);
        }
        else
        {
            success = await VacunaService.CreateAsync(formModel);
        }

        if (success)
        {
            showForm = false;
            await LoadDataAsync();
        }
        else
        {
            errorMessage = isEditing
                ? "Error al actualizar la vacuna."
                : "Error al registrar la vacuna. Verifique que no exista otra con el mismo nombre.";
        }

        isSaving = false;
    }

    private async Task DesactivarVacuna(int id)
    {
        if (await VacunaService.DeleteAsync(id))
        {
            await LoadDataAsync();
        }
    }
}
